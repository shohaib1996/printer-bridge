{
  "name": "better-edibles-print-bridge",
  "version": "1.0.0",
  "description": "Local Windows print bridge for Better Edibles PPS tablet printing",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && xcopy /E /I /Y src\\templates dist\\templates",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "pdfkit": "^0.15.0",
    "bwip-js": "^4.2.0",
    "qrcode": "^1.5.3",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/pdfkit": "^0.13.4",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2",
    "ts-node": "^10.9.2"
  }
}
